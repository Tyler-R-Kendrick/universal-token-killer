{
  "name": "utk-vscode",
  "displayName": "UTK",
  "version": "0.1.0",
  "publisher": "utk",
  "engines": {
    "vscode": "^1.95.0"
  },
  "activationEvents": [
    "onCommand:utk.status",
    "onCommand:utk.cleanupObservations",
    "onCommand:utk.compactSchemaHistory",
    "onCommand:utk.rebuildRoutes",
    "onCommand:utk.validateArtifacts",
    "onCommand:utk.quarantineInvalidArtifacts",
    "onCommand:utk.openStorageFolder"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "utk.status",
        "title": "UTK: Status"
      },
      {
        "command": "utk.cleanupObservations",
        "title": "UTK: Cleanup Observations"
      },
      {
        "command": "utk.compactSchemaHistory",
        "title": "UTK: Compact Schema History"
      },
      {
        "command": "utk.rebuildRoutes",
        "title": "UTK: Rebuild Routes"
      },
      {
        "command": "utk.validateArtifacts",
        "title": "UTK: Validate Artifacts"
      },
      {
        "command": "utk.quarantineInvalidArtifacts",
        "title": "UTK: Quarantine Invalid Artifacts"
      },
      {
        "command": "utk.openStorageFolder",
        "title": "UTK: Open Storage Folder"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0"
  }
}
