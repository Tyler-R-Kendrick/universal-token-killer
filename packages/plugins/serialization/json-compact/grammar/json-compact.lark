start: value

?value: object
      | array
      | string
      | SIGNED_NUMBER
      | "true"
      | "false"
      | "null"

object: "{" [pair ("," pair)*] "}"
pair: string ":" value
array: "[" [value ("," value)*] "]"
string: ESCAPED_STRING

%import common.ESCAPED_STRING
%import common.SIGNED_NUMBER
%import common.WS
%ignore WS
