{
  "mcpServers": {
    "detok": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${workspaceFolder}/packages/detok-mcp/dist/server.js"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "UTK_WORKSPACE_ROOT": "${workspaceFolder}",
        "UTK_LLMLINGUA_MODEL": "microsoft/llmlingua-2-bert-base-multilingual-cased-meetingbank"
      }
    }
  }
}
