{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "baseUrl": "./",
    "paths": {
      "@utk/core": ["packages/core/src/index.ts"],
      "@utk/constrained-decoder": ["packages/constrained-decoder/src/index.ts"]
    }
  }
}
